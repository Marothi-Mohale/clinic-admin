<UserControl x:Class="ClinicAdmin.Desktop.Views.VisitCaptureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="20"
                Background="White"
                BorderBrush="#D8DEE4"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="Visit capture" />
                    <TextBlock Margin="0,8,0,0" Foreground="#5C6670" Text="Search the patient, confirm the record, then register the arrival." />
                    <TextBox Margin="0,16,0,0"
                             Height="38"
                             Padding="12,6"
                             Text="{Binding PatientSearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Margin="16,30,0,0"
                        Width="120"
                        Height="38"
                        Background="#0E7490"
                        Foreground="White"
                        BorderBrush="#0E7490"
                        Command="{Binding SearchPatientsCommand}"
                        Content="Find patient" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Padding="20"
                    Background="White"
                    BorderBrush="#D8DEE4"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="180" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Foreground="#4B5563" Text="{Binding StatusMessage}" TextWrapping="Wrap" />

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding PatientResults}"
                              SelectedItem="{Binding SelectedPatient, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Patient no" Binding="{Binding PatientNumber}" Width="100" />
                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*" />
                            <DataGridTextColumn Header="DOB" Binding="{Binding DateOfBirth}" Width="110" />
                            <DataGridTextColumn Header="File" Binding="{Binding FileNumber}" Width="100" />
                            <DataGridTextColumn Header="Status" Binding="{Binding FileStatus}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Recent visit history" />

                        <ListBox Grid.Row="1"
                                 Margin="0,12,0,0"
                                 ItemsSource="{Binding VisitHistory}"
                                 SelectedItem="{Binding SelectedVisit, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="12"
                                            Background="#F8FAFC"
                                            BorderBrush="#D8DEE4"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding ReasonForVisit}" />
                                            <TextBlock Margin="0,4,0,0" Foreground="#5C6670" Text="{Binding ArrivedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm} UTC}" />
                                            <TextBlock Text="{Binding State, StringFormat=State: {0}}" />
                                            <TextBlock Text="{Binding QueueStatus, StringFormat=Queue: {0}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="20"
                    Background="White"
                    BorderBrush="#D8DEE4"
                    BorderThickness="1"
                    CornerRadius="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="Encounter details" />
                        <TextBlock Margin="0,8,0,0" Foreground="#5C6670" Text="Capture the arrival with the least amount of typing needed." />

                        <TextBlock Margin="0,18,0,6" FontWeight="SemiBold" Text="Reason for visit" />
                        <TextBox Height="36" Text="{Binding ReasonForVisit, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,14,0,6" FontWeight="SemiBold" Text="Queue status" />
                        <ComboBox Height="36"
                                  ItemsSource="{Binding QueueStatusOptions}"
                                  SelectedItem="{Binding SelectedQueueStatus, Mode=TwoWay}" />

                        <TextBlock Margin="0,14,0,6" FontWeight="SemiBold" Text="Visit state" />
                        <ComboBox Height="36"
                                  ItemsSource="{Binding VisitStateOptions}"
                                  SelectedItem="{Binding SelectedVisitState, Mode=TwoWay}" />

                        <TextBlock Margin="0,14,0,6" FontWeight="SemiBold" Text="Department" />
                        <TextBox Height="36" Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,14,0,6" FontWeight="SemiBold" Text="Assigned staff member" />
                        <TextBox Height="36" Text="{Binding AssignedStaffMember, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,14,0,6" FontWeight="SemiBold" Text="Visit notes" />
                        <TextBox Height="100"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />

                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                            <Button Width="130"
                                    Height="40"
                                    Background="#0E7490"
                                    Foreground="White"
                                    BorderBrush="#0E7490"
                                    Command="{Binding RegisterVisitCommand}"
                                    Content="Register visit" />
                            <Button Width="120"
                                    Height="40"
                                    Margin="12,0,0,0"
                                    Command="{Binding UpdateVisitCommand}"
                                    Content="Update visit" />
                            <Button Width="90"
                                    Height="40"
                                    Margin="12,0,0,0"
                                    Command="{Binding ClearVisitFormCommand}"
                                    Content="Clear" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>

