<UserControl x:Class="ClinicAdmin.Desktop.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="20"
                Background="White"
                BorderBrush="#D8DEE4"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Height="36"
                         Margin="0,0,12,0"
                         Padding="12,6"
                         Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Grid.Column="1"
                         Height="36"
                         Margin="0,0,12,0"
                         Padding="12,6"
                         Text="{Binding ActionFilter, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Grid.Column="2"
                         Height="36"
                         Margin="0,0,12,0"
                         Padding="12,6"
                         Text="{Binding EntityFilter, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Grid.Column="3"
                         Height="36"
                         Margin="0,0,12,0"
                         Padding="12,6"
                         Text="{Binding ActorFilter, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="4"
                        Width="110"
                        Height="36"
                        Background="#0E7490"
                        Foreground="White"
                        BorderBrush="#0E7490"
                        Command="{Binding LoadAuditCommand}"
                        Content="Load audit" />
                <Button Grid.Column="5"
                        Width="90"
                        Height="36"
                        Margin="12,0,0,0"
                        Command="{Binding ClearFiltersCommand}"
                        Content="Clear" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Padding="20"
                    Background="White"
                    BorderBrush="#D8DEE4"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Foreground="#4B5563" Text="{Binding StatusMessage}" TextWrapping="Wrap" />

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding AuditItems}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time (UTC)" Binding="{Binding OccurredAtUtc}" Width="160" />
                            <DataGridTextColumn Header="User" Binding="{Binding ActorUsername}" Width="110" />
                            <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="140" />
                            <DataGridTextColumn Header="Entity" Binding="{Binding EntityName}" Width="120" />
                            <DataGridCheckBoxColumn Header="OK" Binding="{Binding Succeeded}" Width="50" />
                            <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="20"
                    Background="White"
                    BorderBrush="#D8DEE4"
                    BorderThickness="1"
                    CornerRadius="18">
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="Audit notes" />
                    <TextBlock Margin="0,10,0,0" Foreground="#5C6670" TextWrapping="Wrap">
                        Audit data is intentionally summarized. Sensitive patient data should be represented as short operational summaries rather than full clinical detail.
                    </TextBlock>
                    <TextBlock Margin="0,18,0,0" FontSize="16" FontWeight="SemiBold" Text="Recommended filters" />
                    <TextBlock Margin="0,8,0,0" Text="AuthenticationAttempt" />
                    <TextBlock Text="PatientRegistered" />
                    <TextBlock Text="VisitRegistered" />
                    <TextBlock Text="VisitUpdated" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

