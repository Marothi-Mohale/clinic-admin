<Window x:Class="ClinicAdmin.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:ClinicAdmin.Desktop.Controls"
        xmlns:converters="clr-namespace:ClinicAdmin.Desktop.Converters"
        xmlns:vm="clr-namespace:ClinicAdmin.Desktop.ViewModels"
        xmlns:views="clr-namespace:ClinicAdmin.Desktop.Views"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="1200"
        Height="760"
        MinWidth="960"
        MinHeight="640"
        Background="#F3F5F7"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:RegistrationStatusBackgroundConverter x:Key="RegistrationStatusBackgroundConverter" />
        <DataTemplate DataType="{x:Type vm:PatientRegistrationViewModel}">
            <views:PatientRegistrationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PatientSearchViewModel}">
            <views:PatientSearchView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VisitCaptureViewModel}">
            <views:VisitCaptureView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditLogViewModel}">
            <views:AuditLogView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WorkspacePlaceholderViewModel}">
            <Border Style="{StaticResource CardBorderStyle}"
                    Padding="28">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding Title}" />
                    <TextBlock Margin="0,14,0,0" Style="{StaticResource SubtleTextStyle}" Text="{Binding Description}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid Visibility="{Binding IsLoginVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Margin="24"
                    Padding="40"
                    Background="{StaticResource ShellBrush}"
                    CornerRadius="24">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="34" FontWeight="SemiBold" Foreground="White" Text="{Binding Title}" />
                    <TextBlock Margin="0,16,0,0"
                               FontSize="16"
                               Foreground="#D6E3EA"
                               TextWrapping="Wrap"
                               Text="{Binding Subtitle}" />
                    <Border Margin="0,28,0,0"
                            Padding="20"
                            Background="{StaticResource ShellAccentBrush}"
                            CornerRadius="16">
                        <StackPanel>
                            <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="White" Text="Phase 1 access" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#D6E3EA"
                                       Text="Use assigned staff credentials to sign in. Demo environments may enable seeded users through configuration."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="24">
                <Border Style="{StaticResource CardBorderStyle}"
                        Padding="36"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Account access" />
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleTextStyle}" Text="Sign in or create a tracked account" />

                        <StackPanel Visibility="{Binding Login.IsRegistrationMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <TextBlock Margin="0,24,0,6" FontWeight="SemiBold" Text="Username" />
                            <TextBox Style="{StaticResource TextInputStyle}"
                                     Text="{Binding Login.Username, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,16,0,6" FontWeight="SemiBold" Text="Password" />
                            <PasswordBox x:Name="PasswordInput"
                                         Height="38"
                                         Padding="12,7"
                                         BorderBrush="{StaticResource BorderBrushNeutral}"
                                         BorderThickness="1"
                                         PasswordChanged="PasswordInput_OnPasswordChanged" />

                            <Button Margin="0,24,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding Login.LoginCommand}"
                                    Content="Sign in" />

                            <Button Margin="0,10,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding Login.OpenRegistrationCommand}"
                                    Content="Create account" />
                        </StackPanel>

                        <StackPanel Visibility="{Binding Login.IsRegistrationMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Margin="0,24,0,6" FontWeight="SemiBold" Text="File Number" />
                            <TextBox Style="{StaticResource TextInputStyle}"
                                     Text="{Binding Login.RegisterFileNumber, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,6" FontWeight="SemiBold" Text="Username" />
                            <TextBox Style="{StaticResource TextInputStyle}"
                                     Text="{Binding Login.RegisterUsername, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,6" FontWeight="SemiBold" Text="Password" />
                            <PasswordBox x:Name="RegisterPasswordInput"
                                         Height="38"
                                         Padding="12,7"
                                         BorderBrush="{StaticResource BorderBrushNeutral}"
                                         BorderThickness="1"
                                         PasswordChanged="RegisterPasswordInput_OnPasswordChanged" />

                            <TextBlock Margin="0,12,0,6" FontWeight="SemiBold" Text="ID Number" />
                            <TextBox Style="{StaticResource TextInputStyle}"
                                     Text="{Binding Login.RegisterIdNumber, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,6" FontWeight="SemiBold" Text="Confirm ID Number" />
                            <TextBox Style="{StaticResource TextInputStyle}"
                                     Text="{Binding Login.RegisterConfirmedIdNumber, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,6" FontWeight="SemiBold" Text="Email" />
                            <TextBox Style="{StaticResource TextInputStyle}"
                                     Text="{Binding Login.RegisterEmail, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,6" FontWeight="SemiBold" Text="Confirm Email" />
                            <TextBox Style="{StaticResource TextInputStyle}"
                                     Text="{Binding Login.RegisterConfirmedEmail, UpdateSourceTrigger=PropertyChanged}" />

                            <Button Margin="0,20,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding Login.RegisterCommand}"
                                    Content="Register account" />

                            <Button Margin="0,10,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding Login.CancelRegistrationCommand}"
                                    Content="Back to sign in" />
                        </StackPanel>

                        <Border Margin="0,16,0,0"
                                Padding="10"
                                Background="{StaticResource WarningSurfaceBrush}"
                                BorderBrush="{StaticResource WarningBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="{Binding Login.StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Foreground="{StaticResource WarningBrush}" Text="{Binding Login.StatusMessage}" TextWrapping="Wrap" />
                        </Border>

                        <Border Margin="0,16,0,0"
                                Padding="10"
                                Background="{StaticResource DangerSurfaceBrush}"
                                BorderBrush="#E7B4B4"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="{Binding Login.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Foreground="{StaticResource DangerBrush}" Text="{Binding Login.ErrorMessage}" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Visibility="{Binding IsShellVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource ShellBrush}">
                <DockPanel Margin="20">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="White" Text="{Binding Title}" />
                        <TextBlock Margin="0,8,0,0" Foreground="#D6E3EA" Text="{Binding CurrentUserDisplayName}" />
                        <TextBlock Foreground="#9BC3D6" Text="{Binding CurrentRole}" />
                    </StackPanel>

                    <StackPanel Margin="0,28,0,0">
                        <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#9BC3D6" Text="Navigation" />
                        <ListBox ItemsSource="{Binding NavigationItems}"
                                 SelectedValue="{Binding SelectedRoute, Mode=TwoWay}"
                                 SelectedValuePath="Route"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,6,0,0" Padding="12" Background="{StaticResource ShellAccentBrush}" CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       FontSize="12"
                                                       Foreground="#D6E3EA"
                                                       Text="{Binding Description}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <Button DockPanel.Dock="Bottom"
                            Margin="0,24,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding LogoutCommand}"
                            Content="Sign out" />
                </DockPanel>
            </Border>

            <Grid Grid.Column="1" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="{Binding SelectedRoute}" />
                    <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleTextStyle}" Text="{Binding CurrentRouteDescription}" />
                </StackPanel>

                <ContentControl Grid.Row="2" Content="{Binding CurrentWorkspaceViewModel}" />
            </Grid>
        </Grid>
    </Grid>
</Window>
