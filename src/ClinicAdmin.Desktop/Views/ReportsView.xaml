<UserControl x:Class="ClinicAdmin.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="20"
                Background="White"
                BorderBrush="#D8DEE4"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="From" />
                <DatePicker Grid.Column="1"
                            SelectedDate="{Binding FromDate, Mode=TwoWay}"
                            Height="34" />
                <TextBlock Grid.Column="3" VerticalAlignment="Center" FontWeight="SemiBold" Text="To" />
                <DatePicker Grid.Column="4"
                            SelectedDate="{Binding ToDate, Mode=TwoWay}"
                            Height="34" />

                <Button Grid.Column="6"
                        Width="120"
                        Height="34"
                        HorizontalAlignment="Right"
                        Background="#0E7490"
                        Foreground="White"
                        BorderBrush="#0E7490"
                        Command="{Binding LoadReportCommand}"
                        Content="Load report" />
                <Button Grid.Column="7"
                        Width="120"
                        Height="34"
                        Margin="12,0,0,0"
                        Command="{Binding ExportCsvCommand}"
                        Content="Export CSV" />
                <Button Grid.Column="8"
                        Width="90"
                        Height="34"
                        Margin="12,0,0,0"
                        Command="{Binding ResetFiltersCommand}"
                        Content="Reset" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Padding="18" Background="White" BorderBrush="#D8DEE4" BorderThickness="1" CornerRadius="18">
                <StackPanel>
                    <TextBlock Foreground="#5C6670" Text="Total registrations" />
                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Text="{Binding TotalRegistrations}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Padding="18" Background="White" BorderBrush="#D8DEE4" BorderThickness="1" CornerRadius="18">
                <StackPanel>
                    <TextBlock Foreground="#5C6670" Text="Total visits" />
                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="SemiBold" Text="{Binding TotalVisits}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Padding="18" Background="White" BorderBrush="#D8DEE4" BorderThickness="1" CornerRadius="18">
                <TextBlock Foreground="#4B5563" Text="{Binding StatusMessage}" TextWrapping="Wrap" VerticalAlignment="Center" />
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.3*" />
            </Grid.ColumnDefinitions>

            <Border Padding="18" Background="White" BorderBrush="#D8DEE4" BorderThickness="1" CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Daily registrations" />
                    <DataGrid Grid.Row="2" ItemsSource="{Binding DailyRegistrations}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*" />
                            <DataGridTextColumn Header="Registrations" Binding="{Binding RegistrationCount}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="18" Background="White" BorderBrush="#D8DEE4" BorderThickness="1" CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Visits per day" />
                    <DataGrid Grid.Row="2" ItemsSource="{Binding DailyVisits}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*" />
                            <DataGridTextColumn Header="Visits" Binding="{Binding VisitCount}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="4" Padding="18" Background="White" BorderBrush="#D8DEE4" BorderThickness="1" CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Common reasons for visit" />
                    <DataGrid Grid.Row="2" ItemsSource="{Binding CommonReasons}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Reason" Binding="{Binding ReasonForVisit}" Width="*" />
                            <DataGridTextColumn Header="Visits" Binding="{Binding VisitCount}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Padding="18" Background="White" BorderBrush="#D8DEE4" BorderThickness="1" CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Staff activity summary" />
                    <DataGrid Grid.Row="2" ItemsSource="{Binding StaffActivity}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Staff" Binding="{Binding DisplayName}" Width="*" />
                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="110" />
                            <DataGridTextColumn Header="Logins" Binding="{Binding SuccessfulLogins}" Width="70" />
                            <DataGridTextColumn Header="Failed" Binding="{Binding FailedLogins}" Width="70" />
                            <DataGridTextColumn Header="Registrations" Binding="{Binding PatientRegistrations}" Width="100" />
                            <DataGridTextColumn Header="Visits" Binding="{Binding VisitsRegistered}" Width="70" />
                            <DataGridTextColumn Header="Updates" Binding="{Binding VisitsUpdated}" Width="70" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="3" Padding="18" Background="White" BorderBrush="#D8DEE4" BorderThickness="1" CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Patient visit history summary" />
                    <DataGrid Grid.Row="2" ItemsSource="{Binding PatientVisitHistory}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Patient no" Binding="{Binding PatientNumber}" Width="110" />
                            <DataGridTextColumn Header="Patient" Binding="{Binding DisplayName}" Width="*" />
                            <DataGridTextColumn Header="Visits" Binding="{Binding VisitCount}" Width="70" />
                            <DataGridTextColumn Header="Last visit (UTC)" Binding="{Binding LastVisitAtUtc}" Width="160" />
                            <DataGridTextColumn Header="Last reason" Binding="{Binding LastReasonForVisit}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
