<UserControl x:Class="ClinicAdmin.Desktop.Views.PatientSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ClinicAdmin.Desktop.Controls"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Patient search" />
                    <TextBlock Margin="0,8,0,0"
                               Style="{StaticResource SubtleTextStyle}"
                               Text="Search by patient number, ID, passport, phone number, surname, or full name." />
                    <TextBox Margin="0,16,0,0"
                             Style="{StaticResource TextInputStyle}"
                             Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Margin="16,30,0,0"
                        Width="120"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SearchCommand}"
                        Content="Search" />

                <Button Grid.Column="2"
                        Margin="12,30,0,0"
                        Width="100"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ClearSearchCommand}"
                        Content="Clear" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource SubtleTextStyle}" Text="{Binding StatusMessage}" />

                    <Grid Grid.Row="2">
                        <controls:EmptyStateView Visibility="{Binding HasResults, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                                 Title="No patient selected"
                                                 Message="{Binding StatusMessage}" />

                        <DataGrid ItemsSource="{Binding Results}"
                                  SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                                  Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Style="{StaticResource FlatDataGridStyle}"
                                  SelectionMode="Single"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Patient no" Binding="{Binding PatientNumber}" Width="110" />
                                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*" />
                                <DataGridTextColumn Header="DOB" Binding="{Binding DateOfBirth}" Width="110" />
                                <DataGridTextColumn Header="ID / Passport" Binding="{Binding Identifier}" Width="140" />
                                <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="120" />
                                <DataGridTextColumn Header="File" Binding="{Binding FileNumber}" Width="100" />
                                <DataGridTextColumn Header="Status" Binding="{Binding FileStatus}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}" Text="{Binding SelectedProfile.DisplayName}" />
                        <TextBlock Margin="0,8,0,0" Style="{StaticResource SubtleTextStyle}" Text="{Binding SelectedProfile.PatientNumber, StringFormat=Patient no: {0}}" />
                        <TextBlock Style="{StaticResource SubtleTextStyle}" Text="{Binding SelectedProfile.Summary}" />
                    </StackPanel>

                    <Button Grid.Row="1"
                            Width="120"
                            Margin="0,14,0,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenProfileCommand}"
                            Content="Open profile" />

                    <ScrollViewer Grid.Row="2" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,18,0,0">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="File retrieval" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding SelectedProfile.FileNumber, StringFormat=File number: {0}}" />
                            <TextBlock Text="{Binding SelectedProfile.FileStatus, StringFormat=Status: {0}}" />
                            <TextBlock Text="{Binding SelectedProfile.FileLocation, StringFormat=Location: {0}}" />

                            <TextBlock Margin="0,18,0,0" FontSize="16" FontWeight="SemiBold" Text="Contact" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding SelectedProfile.PhoneNumber, StringFormat=Phone: {0}}" />
                            <TextBlock Text="{Binding SelectedProfile.NationalIdNumber, StringFormat=National ID: {0}}" />
                            <TextBlock Text="{Binding SelectedProfile.PassportNumber, StringFormat=Passport: {0}}" />

                            <TextBlock Margin="0,18,0,0" FontSize="16" FontWeight="SemiBold" Text="Address" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding SelectedProfile.Address}" TextWrapping="Wrap" />

                            <TextBlock Margin="0,18,0,0" FontSize="16" FontWeight="SemiBold" Text="Next of kin" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding SelectedProfile.NextOfKin}" TextWrapping="Wrap" />

                            <TextBlock Margin="0,18,0,0" FontSize="16" FontWeight="SemiBold" Text="History summary" />
                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SelectedProfile.History}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Style="{StaticResource SecondaryCardBorderStyle}"
                                                Padding="10">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Action}" />
                                                <TextBlock Margin="0,4,0,0" Style="{StaticResource SubtleTextStyle}" Text="{Binding OccurredAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm} UTC}" />
                                                <TextBlock Margin="0,4,0,0" Text="{Binding Details}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
