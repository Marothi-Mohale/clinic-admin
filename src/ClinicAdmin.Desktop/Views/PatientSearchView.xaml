<UserControl x:Class="ClinicAdmin.Desktop.Views.PatientSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="20"
                Background="White"
                BorderBrush="#D8DEE4"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="Patient search" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#5C6670"
                               Text="Search by patient number, ID, passport, phone number, surname, or full name." />
                    <TextBox Margin="0,16,0,0"
                             Height="38"
                             Padding="12,6"
                             Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Margin="16,30,0,0"
                        Width="120"
                        Height="38"
                        Background="#0E7490"
                        Foreground="White"
                        BorderBrush="#0E7490"
                        Command="{Binding SearchCommand}"
                        Content="Search" />

                <Button Grid.Column="2"
                        Margin="12,30,0,0"
                        Width="100"
                        Height="38"
                        Command="{Binding ClearSearchCommand}"
                        Content="Clear" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Padding="20"
                    Background="White"
                    BorderBrush="#D8DEE4"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Foreground="#4B5563" Text="{Binding StatusMessage}" TextWrapping="Wrap" />

                    <Grid Grid.Row="2">
                        <TextBlock Visibility="{Binding HasResults, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="#6B7280"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center" />

                        <DataGrid ItemsSource="{Binding Results}"
                                  SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                                  Visibility="{Binding HasResults, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  SelectionMode="Single"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Patient no" Binding="{Binding PatientNumber}" Width="110" />
                                <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*" />
                                <DataGridTextColumn Header="DOB" Binding="{Binding DateOfBirth}" Width="110" />
                                <DataGridTextColumn Header="ID / Passport" Binding="{Binding Identifier}" Width="140" />
                                <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="120" />
                                <DataGridTextColumn Header="File" Binding="{Binding FileNumber}" Width="100" />
                                <DataGridTextColumn Header="Status" Binding="{Binding FileStatus}" Width="110" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="20"
                    Background="White"
                    BorderBrush="#D8DEE4"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding SelectedProfile.DisplayName}" />
                        <TextBlock Margin="0,8,0,0" Foreground="#5C6670" Text="{Binding SelectedProfile.PatientNumber, StringFormat=Patient no: {0}}" />
                        <TextBlock Foreground="#5C6670" Text="{Binding SelectedProfile.Summary}" />
                    </StackPanel>

                    <Button Grid.Row="1"
                            Width="120"
                            Height="34"
                            Margin="0,14,0,0"
                            HorizontalAlignment="Left"
                            Command="{Binding OpenProfileCommand}"
                            Content="Open profile" />

                    <ScrollViewer Grid.Row="2" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,18,0,0">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="File retrieval" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding SelectedProfile.FileNumber, StringFormat=File number: {0}}" />
                            <TextBlock Text="{Binding SelectedProfile.FileStatus, StringFormat=Status: {0}}" />
                            <TextBlock Text="{Binding SelectedProfile.FileLocation, StringFormat=Location: {0}}" />

                            <TextBlock Margin="0,18,0,0" FontSize="16" FontWeight="SemiBold" Text="Contact" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding SelectedProfile.PhoneNumber, StringFormat=Phone: {0}}" />
                            <TextBlock Text="{Binding SelectedProfile.NationalIdNumber, StringFormat=National ID: {0}}" />
                            <TextBlock Text="{Binding SelectedProfile.PassportNumber, StringFormat=Passport: {0}}" />

                            <TextBlock Margin="0,18,0,0" FontSize="16" FontWeight="SemiBold" Text="Address" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding SelectedProfile.Address}" TextWrapping="Wrap" />

                            <TextBlock Margin="0,18,0,0" FontSize="16" FontWeight="SemiBold" Text="Next of kin" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding SelectedProfile.NextOfKin}" TextWrapping="Wrap" />

                            <TextBlock Margin="0,18,0,0" FontSize="16" FontWeight="SemiBold" Text="History summary" />
                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SelectedProfile.History}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="10"
                                                Background="#F8FAFC"
                                                BorderBrush="#D8DEE4"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Action}" />
                                                <TextBlock Margin="0,4,0,0" Foreground="#5C6670" Text="{Binding OccurredAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm} UTC}" />
                                                <TextBlock Margin="0,4,0,0" Text="{Binding Details}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
