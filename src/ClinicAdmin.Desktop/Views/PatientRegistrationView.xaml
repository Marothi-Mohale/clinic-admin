<UserControl x:Class="ClinicAdmin.Desktop.Views.PatientRegistrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.2*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <Border Padding="24"
                Background="#FBFCFD"
                BorderBrush="#D8DEE4"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="Register patient" />
                    <TextBlock Margin="0,8,0,0" Foreground="#5C6670" Text="Capture the essential details quickly. Use Tab to move through fields." />
                </StackPanel>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <UniformGrid Columns="2" Margin="0,0,0,18">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="Patient number" />
                                <TextBox Height="36" Margin="0,6,0,0" Text="{Binding PatientNumber, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock FontWeight="SemiBold" Text="Phone number" />
                                <TextBox Height="36" Margin="0,6,0,0" Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Columns="2" Margin="0,0,0,18">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="First name" />
                                <TextBox Height="36" Margin="0,6,0,0" Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock FontWeight="SemiBold" Text="Surname" />
                                <TextBox Height="36" Margin="0,6,0,0" Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Columns="2" Margin="0,0,0,18">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="Date of birth" />
                                <DatePicker Margin="0,6,0,0" SelectedDate="{Binding DateOfBirth, Mode=TwoWay}" />
                            </StackPanel>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock FontWeight="SemiBold" Text="Sex" />
                                <ComboBox Margin="0,6,0,0"
                                          Height="36"
                                          ItemsSource="{Binding SexOptions}"
                                          SelectedItem="{Binding SelectedSex, Mode=TwoWay}" />
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Columns="2" Margin="0,0,0,18">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="National ID number" />
                                <TextBox Height="36" Margin="0,6,0,0" Text="{Binding NationalIdNumber, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock FontWeight="SemiBold" Text="Passport number" />
                                <TextBox Height="36" Margin="0,6,0,0" Text="{Binding PassportNumber, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Margin="0,0,0,6" FontSize="16" FontWeight="SemiBold" Text="Address" />
                        <TextBox Height="36" Margin="0,0,0,10" Text="{Binding AddressLine1, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Height="36" Margin="0,0,0,10" Text="{Binding AddressLine2, UpdateSourceTrigger=PropertyChanged}" />
                        <UniformGrid Columns="2" Margin="0,0,0,18">
                            <TextBox Margin="0,0,12,0" Height="36" Text="{Binding Suburb, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Margin="12,0,0,0" Height="36" Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" />
                        </UniformGrid>

                        <TextBlock Margin="0,0,0,6" FontSize="16" FontWeight="SemiBold" Text="Next of kin" />
                        <UniformGrid Columns="2" Margin="0,0,0,18">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontWeight="SemiBold" Text="Full name" />
                                <TextBox Height="36" Margin="0,6,0,0" Text="{Binding NextOfKinName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock FontWeight="SemiBold" Text="Relationship" />
                                <TextBox Height="36" Margin="0,6,0,0" Text="{Binding NextOfKinRelationship, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </UniformGrid>
                        <StackPanel Margin="0,0,0,18">
                            <TextBlock FontWeight="SemiBold" Text="Next of kin phone number" />
                            <TextBox Height="36" Margin="0,6,0,0" Text="{Binding NextOfKinPhoneNumber, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="3">
                    <Border Padding="12"
                            Background="{Binding StatusIsError, Converter={StaticResource RegistrationStatusBackgroundConverter}}"
                            CornerRadius="12">
                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Width="140"
                                Height="40"
                                Background="#0E7490"
                                Foreground="White"
                                BorderBrush="#0E7490"
                                Command="{Binding SaveCommand}"
                                Content="Save patient" />
                        <Button Width="140"
                                Height="40"
                                Margin="12,0,0,0"
                                Command="{Binding CheckDuplicatesCommand}"
                                Content="Check duplicates" />
                        <Button Width="120"
                                Height="40"
                                Margin="12,0,0,0"
                                Command="{Binding ClearFormCommand}"
                                Content="Clear form" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Padding="20"
                Background="White"
                BorderBrush="#D8DEE4"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Duplicate review" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#5C6670"
                               Text="Warnings appear here before saving so reception staff can stop duplicate creation early."
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="1">
                    <TextBlock Visibility="{Binding HasDuplicateWarnings, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                               Foreground="#6B7280"
                               VerticalAlignment="Center"
                               Text="No duplicate warnings yet. Capture the patient details and use Check duplicates or Save patient." 
                               TextWrapping="Wrap" />

                    <ListBox ItemsSource="{Binding DuplicateWarnings}"
                             Visibility="{Binding HasDuplicateWarnings, Converter={StaticResource BooleanToVisibilityConverter}}"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        BorderBrush="#E2A93B"
                                        BorderThickness="1"
                                        Background="#FFF9EC"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                        <TextBlock Margin="0,6,0,0" Text="{Binding PatientNumber, StringFormat=Patient no: {0}}" />
                                        <TextBlock Text="{Binding DateOfBirth, StringFormat=DOB: {0}}" />
                                        <TextBlock Text="{Binding Strength, StringFormat=Strength: {0}}" />
                                        <TextBlock Text="{Binding Recommendation, StringFormat=Action: {0}}" />
                                        <TextBlock Margin="0,8,0,0" Foreground="#92400E" Text="{Binding ReasonSummary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <CheckBox Grid.Row="2"
                          Visibility="{Binding HasDuplicateWarnings, Converter={StaticResource BooleanToVisibilityConverter}}"
                          IsChecked="{Binding DuplicateWarningAcknowledged, Mode=TwoWay}"
                          Content="I reviewed the warnings and confirm this is a different patient." />
            </Grid>
        </Border>
    </Grid>
</UserControl>

